#!/usr/bin/env bash
{{ if eq .profile "mac" -}}
set -euo pipefail

# run_onchange: re-runs on `chezmoi apply` whenever the Brewfile changes.
# chezmoi hashes only this script's rendered content, not the Brewfile it reads
# at runtime, so the hash below is embedded to make edits retrigger it.
# brew bundle is idempotent (installed formulae/casks are skipped).
#
# Brewfile: {{ include "packages/Brewfile" | sha256sum }}

if ! command -v brew >/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brewfile="{{ .chezmoi.sourceDir }}/packages/Brewfile"
[ -f "$brewfile" ] || { echo "no $brewfile — skipping"; exit 0; }

brew bundle --file="$brewfile"
{{ end -}}
