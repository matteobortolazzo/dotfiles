#!/usr/bin/env bash
{{ if eq .chezmoi.os "linux" -}}
set -euo pipefail

# matches PATH entry in .zshrc: /opt/nvim-linux-x86_64/bin
[ -x /opt/nvim-linux-x86_64/bin/nvim ] && exit 0

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
curl -fsSL -o "$tmp" https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
sudo tar -C /opt -xzf "$tmp"
{{ end -}}
