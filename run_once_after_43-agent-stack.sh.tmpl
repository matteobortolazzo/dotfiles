#!/usr/bin/env bash
{{ if eq .chezmoi.os "linux" "darwin" -}}
set -euo pipefail

# claude is the native build in ~/.local/bin — make sure it's on PATH for
# this non-interactive script, or the agent-stack step silently never runs.
export PATH="$HOME/.local/bin:$PATH"

# claude (native installer; replaces the old @anthropic-ai/claude-code npm global)
if ! command -v claude >/dev/null; then
  curl -fsSL https://claude.ai/install.sh | bash
fi

# agent-stack — one installer for the whole trio (agentflow + agentwatch +
# sandbox), replacing the old ccflow / muxwatch / claude-sand setup. --yes runs
# non-interactively; the sandbox image build is skipped in that mode (run
# `agent-sand --build` once a container runtime is ready). The agentwatch binary
# self-bootstraps on first session, so no `go install` step is needed here.
if command -v claude >/dev/null; then
  curl -fsSL https://raw.githubusercontent.com/matteobortolazzo/agent-stack/main/install.sh | bash -s -- --yes
fi
{{ end -}}
