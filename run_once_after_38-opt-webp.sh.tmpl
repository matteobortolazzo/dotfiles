#!/usr/bin/env bash
{{ if eq .chezmoi.os "linux" -}}
set -euo pipefail

# matches PATH entry in .zshrc: /opt/webp
[ -x /opt/webp/bin/cwebp ] && exit 0

ver="1.4.0"
tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

url="https://storage.googleapis.com/downloads.webmproject.org/releases/webp/libwebp-${ver}-linux-x86-64.tar.gz"
curl -fsSL -o "$tmp/webp.tar.gz" "$url"
tar -C "$tmp" -xzf "$tmp/webp.tar.gz"

sudo rm -rf /opt/webp
sudo mv "$tmp/libwebp-${ver}-linux-x86-64" /opt/webp
{{ end -}}
