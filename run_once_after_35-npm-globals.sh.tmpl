#!/usr/bin/env bash
{{ if eq .chezmoi.os "linux" "darwin" -}}
set -euo pipefail

if ! command -v fnm >/dev/null; then
  echo "fnm not found — skipping npm globals"
  exit 0
fi

eval "$(fnm env)"

# Ensure a user-owned fnm Node exists; otherwise npm falls back to the
# system (Homebrew) prefix, which may be foreign-owned → EACCES on install.
current="$(fnm current 2>/dev/null || echo none)"
if [ "$current" = "system" ] || [ "$current" = "none" ]; then
  fnm install --lts
  fnm default lts-latest
  fnm use lts-latest
fi

if ! command -v npm >/dev/null; then
  echo "npm not found — skipping npm globals"
  exit 0
fi

packages=(
  playwright
)

for pkg in "${packages[@]}"; do
  if ! npm list -g "$pkg" >/dev/null 2>&1; then
    npm install -g "$pkg"
  fi
done

# Claude Code moved to the native installer (run_once_after_43) — drop the
# old npm global so `claude` doesn't warn about multiple installations.
if npm list -g @anthropic-ai/claude-code >/dev/null 2>&1; then
  npm uninstall -g @anthropic-ai/claude-code
fi
{{ end -}}
