{
  "cleanupPeriodDays": 7,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "1"
  },
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"Claude Code: \" + (.message // \"Needs attention\")' | xargs -0 notify-send 'Claude Code'",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "ccflow@ccflow": true,
    "muxwatch@muxwatch": true,
    "dotnet-nuget-proxy@dotnet-nuget-proxy": true
  },
  "extraKnownMarketplaces": {
    "ccflow": {
      "source": {
        "source": "github",
        "repo": "matteobortolazzo/ccflow"
      }
    },
    "muxwatch": {
      "source": {
        "source": "github",
        "repo": "matteobortolazzo/muxwatch"
      }
    },
    "dotnet-nuget-proxy": {
      "source": {
        "source": "github",
        "repo": "logiclabs/dotnet-nuget-proxy-skill"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Sganassando",
      "Ciapando",
      "Sbatociando",
      "Magnando",
      "Tociando",
      "Sbregando",
      "Ingrumando",
      "Sbolsegando",
      "Ingropando",
      "Smanegando",
      "Strucando",
      "Imbrojando",
      "Tacando",
      "Scampando",
      "Porconando",
      "Sbrissando",
      "Bajando",
      "Pareciando"
    ]
  },
  "effortLevel": "high"
}