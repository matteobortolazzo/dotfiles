#!/usr/bin/env bash
{{ if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") (eq .chezmoi.osRelease.id "cachyos" "arch") (eq .profile "main") -}}
set -euo pipefail

# noctalia-qs currently satisfies dms-shell's quickshell dependency, but its
# FloatingWindow API rejects several DMS parentWindow assignments. Keep a
# patched user-owned DMS tree available for the dms-run-session wrapper.

src=/usr/share/quickshell/dms
base="$HOME/.local/share/dms-shell-hotfix"
current="$base/current"

if ! command -v dms >/dev/null 2>&1 || ! command -v quickshell >/dev/null 2>&1 || ! [ -d "$src" ]; then
  exit 0
fi

if ! quickshell --version 2>/dev/null | grep -q '^noctalia-qs '; then
  exit 0
fi

version=$(cat "$src/VERSION" 2>/dev/null | tr -d '\n' || printf unknown)
version=$(printf '%s' "$version" | tr -c 'A-Za-z0-9._-' '-')
qs_version=$(quickshell --version 2>/dev/null || true)
pkg_versions=$(pacman -Q dms-shell noctalia-qs qt6-base qt6-declarative 2>/dev/null || true)
patch_files='
Modals/FileBrowser/FileBrowserModal.qml
Modules/Settings/DesktopWidgetBrowser.qml
Modules/Settings/PluginBrowser.qml
Modules/Settings/ThemeBrowser.qml
Modules/Settings/Widgets/AppBrowserPopup.qml
Modules/Settings/WidgetSelectionPopup.qml
'

patch_inputs=$(
  for file in $patch_files; do
    [ -f "$src/$file" ] && sed -n '/^[[:space:]]*parentWindow:/p' "$src/$file"
  done
)

hash=$(printf '%s\n%s\n%s\n%s\n' "$version" "$qs_version" "$pkg_versions" "$patch_inputs" | sha256sum | awk '{print substr($1, 1, 12)}')
target="$base/dms-$version-noctalia-qs-$hash"

mkdir -p "$base"

if ! [ -d "$target" ]; then
  tmp="$base/.tmp-$hash-$$"
  rm -rf "$tmp"
  cp -a "$src" "$tmp"

  for file in $patch_files; do
    [ -f "$tmp/$file" ] && sed -i '/^[[:space:]]*parentWindow:/d' "$tmp/$file"
  done

  mv "$tmp" "$target"
  echo "installed DMS noctalia-qs hotfix at $target"
fi

if [ -e "$current" ] && ! [ -L "$current" ]; then
  echo "$current exists and is not a symlink; leaving it unchanged" >&2
  exit 1
fi

ln -sfn "$target" "$current"

if systemctl --user list-unit-files dms.service >/dev/null 2>&1; then
  systemctl --user daemon-reload || true
fi
{{ end -}}
