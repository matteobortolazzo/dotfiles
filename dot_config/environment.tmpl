# Secrets managed by 1Password — populated by chezmoi apply
# To update values, edit items in 1Password, then re-run chezmoi apply

# OpenAI
export OPENAI_API_KEY="{{ onepasswordRead "op://Private/OpenAI/ApiKey" }}"

# Anthropic
export ANTHROPIC_API_KEY="{{ onepasswordRead "op://Private/Anthropic API Key/credential" }}"

# Context7
export CONTEXT7_API_KEY="{{ onepasswordRead "op://Private/Context7 API Key/credential" }}"

# Resend
export RESEND_API_KEY="{{ onepasswordRead "op://Private/Resend/ApiKey" }}"
export RESEND_FROM_ADDRESS="{{ onepasswordRead "op://Private/Resend/FromAddress" }}"
