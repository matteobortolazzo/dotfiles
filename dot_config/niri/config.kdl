// niri config — ported from dot_config/hypr/hyprland.conf
// Coexists with Hyprland; selectable at greetd login.
// Shell: DankMaterialShell (dms), pulled in by `systemctl --user add-wants niri.service dms`.
// Terminal: ghostty.

input {
    keyboard {
        xkb {
            layout "us"
        }
    }

    touchpad {
        tap
        dwt
        natural-scroll
        click-method "clickfinger"
    }

    mouse {
        // mirrors Hyprland `sensitivity = 0`
        accel-speed 0.0
    }

    focus-follows-mouse
    workspace-auto-back-and-forth
}

// DP-4 (external 2560x1440) at 0,0; eDP-1 (laptop, scaled 2x → 1440x900 logical) on the bottom-left, bottoms aligned.
output "DP-4" {
    position x=0 y=0
    scale 1.0
}

output "eDP-1" {
    position x=-1440 y=540
    scale 2.0
}

// Hyprland env = lines (HYPRCURSOR_SIZE dropped — Hyprland-only)
environment {
    XCURSOR_SIZE "24"
    LIBVA_DRIVER_NAME "nvidia"
    __GLX_VENDOR_LIBRARY_NAME "nvidia"
    // Force Mozilla apps (Zen, Firefox, Thunderbird) onto native Wayland.
    // Without this they fall back to XWayland and ignore niri's
    // rounded-corner clipping, showing square opaque borders.
    MOZ_ENABLE_WAYLAND "1"
}

// Spawned at session start (replaces Hyprland exec-once)
// noctalia is NOT spawned: dms is pulled in via niri.service Wants=dms.
spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
spawn-at-startup "xwayland-satellite"
spawn-at-startup "zen-browser"
spawn-at-startup "ghostty"
spawn-at-startup "1password" "--silent"
spawn-at-startup "/opt/tuxedo-control-center/tuxedo-control-center" "--tray"

xwayland-satellite {
    path "/usr/bin/xwayland-satellite"
}

prefer-no-csd
hotkey-overlay {
    skip-at-startup
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

layout {
    gaps 8

    // Only center when columns overflow the screen; full-width single
    // window on a laptop is more useful than always-centered with margins.
    center-focused-column "on-overflow"

    default-column-width { proportion 1.0; }

    preset-column-widths {
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    // Transparent workspace background lets the wallpaper (placed within
    // the backdrop via layer-rule below) show through transparent and
    // fullscreen windows. Required for the "see-through to wallpaper"
    // effect on transparent terminals.
    background-color "transparent"

    focus-ring {
        off
    }

    border {
        width 1
        active-color "rgba(255,255,255,0.15)"
        inactive-color "rgba(255,255,255,0.08)"
    }

    shadow {
        on
        softness 20
        spread 0
        offset x=0 y=0
        color "rgba(0,0,0,0.25)"
    }

    struts {
        left 0
        right 0
        top 0
        bottom 0
    }
}

animations {
    // Closest to Hyprland's "glass" feel
    workspace-switch {
        spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001
    }
    window-open {
        duration-ms 200
        curve "ease-out-quad"
    }
    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }
}

overview {
    backdrop-color "rgba(20,20,24,0.75)"
}

// DMS IPC shorthand: `dms ipc call <module> <action>`
// If the verb turns out to be different (e.g. `dms-cli`), search/replace here.

binds {
    // Hotkey overlay
    Mod+Slash { show-hotkey-overlay; }

    // Programs
    Mod+T       { spawn "ghostty"; }
    // Focus existing Zen window if any; else launch. Avoids the
    // double-window issue caused by Firefox-style remote startup
    // and by session restore.
    Mod+B       cooldown-ms=750 { spawn-sh "$HOME/.config/niri/scripts/focus-or-spawn.sh zen zen-browser"; }
    Mod+E       { spawn "thunar"; }
    Mod+D       { spawn "dms" "ipc" "call" "spotlight" "toggle"; }
    Mod+Print   { spawn "sh" "-c" "grim -g \"$(slurp)\" - | wl-copy -t image/png"; }
    Mod+N       { spawn-sh "$HOME/.config/hypr/scripts/dictation-toggle.sh"; }

    // Compositor
    Mod+Q       { close-window; }
    Mod+V       { toggle-window-floating; }
    Mod+M       { maximize-column; }
    Mod+Z       { fullscreen-window; }
    Mod+R       { spawn "dms" "ipc" "call" "settings" "toggle"; }
    Mod+P       { expel-window-from-column; }
    Mod+G       { toggle-column-tabbed-display; }

    // Shell (DMS)
    Mod+A             { spawn "dms" "ipc" "call" "control-center" "toggle"; }
    Mod+W             { spawn "dms" "ipc" "call" "wallpaper" "next"; }
    Mod+Shift+N       { spawn "dms" "ipc" "call" "notifications" "toggle"; }
    Mod+Shift+D       { spawn "dms" "ipc" "call" "notifications" "toggleDoNotDisturb"; }

    // System
    Mod+Escape           { spawn "dms" "ipc" "call" "lock" "lock"; }
    Ctrl+Alt+Delete      { spawn "dms" "ipc" "call" "powermenu" "toggle"; }

    // Focus columns/windows (vim keys)
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }

    // Move window in scrolling layout (vim keys)
    Mod+Shift+H { move-column-left; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }
    Mod+Shift+L { move-column-right; }

    // Build/tear stacked columns. Toggles: if a neighbor exists in that
    // direction, pull it into this column; if focused window is already
    // stacked, expel it back out as a new column.
    Mod+Comma  { consume-or-expel-window-left; }
    Mod+Period { consume-or-expel-window-right; }

    // Move window left/right
    Mod+Shift+Comma  { move-column-left; }
    Mod+Shift+Period { move-column-right; }

    // Monitor focus + move
    Mod+Alt+Comma         { focus-monitor-left; }
    Mod+Alt+Period        { focus-monitor-right; }
    Mod+Alt+Shift+Comma   { move-window-to-monitor-left; }
    Mod+Alt+Shift+Period  { move-window-to-monitor-right; }

    // Workspace navigation (niri = vertical workspaces, per-output dynamic)
    Mod+BracketLeft        { focus-workspace-up; }
    Mod+BracketRight       { focus-workspace-down; }
    Mod+Shift+BracketLeft  { move-window-to-workspace-up; }
    Mod+Shift+BracketRight { move-window-to-workspace-down; }

    // Direct workspace switching (per-output indexed)
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    // Move window to workspace
    Mod+Shift+1 { move-window-to-workspace 1; }
    Mod+Shift+2 { move-window-to-workspace 2; }
    Mod+Shift+3 { move-window-to-workspace 3; }
    Mod+Shift+4 { move-window-to-workspace 4; }
    Mod+Shift+5 { move-window-to-workspace 5; }
    Mod+Shift+6 { move-window-to-workspace 6; }
    Mod+Shift+7 { move-window-to-workspace 7; }
    Mod+Shift+8 { move-window-to-workspace 8; }
    Mod+Shift+9 { move-window-to-workspace 9; }

    // Overview (niri equivalent to a scratchpad/glance view)
    Mod+S       { toggle-overview; }

    // Scroll workspaces with Mod+wheel
    Mod+WheelScrollDown   cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp     cooldown-ms=150 { focus-workspace-up; }
    Mod+WheelScrollRight  cooldown-ms=150 { focus-column-right; }
    Mod+WheelScrollLeft   cooldown-ms=150 { focus-column-left; }

    // Column width
    Mod+Ctrl+H       { set-column-width "-10%"; }
    Mod+Ctrl+L       { set-column-width "+10%"; }
    Mod+Ctrl+Comma   { switch-preset-column-width-back; }
    Mod+Ctrl+Period  { switch-preset-column-width; }

    // Fit ops (hyprscroller analogs)
    Mod+F        { maximize-column; }
    Mod+Shift+F  { center-visible-columns; }

    // Move entire column across workspaces
    Mod+Ctrl+Shift+Comma  { move-column-to-workspace-up; }
    Mod+Ctrl+Shift+Period { move-column-to-workspace-down; }

    // Audio (DMS) + brightness
    XF86AudioRaiseVolume     allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "increment"; }
    XF86AudioLowerVolume     allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "decrement"; }
    XF86AudioMute            allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "mute"; }
    XF86AudioMicMute         allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "micmute"; }
    XF86MonBrightnessUp      allow-when-locked=true { spawn "dms" "ipc" "call" "brightness" "increment"; }
    XF86MonBrightnessDown    allow-when-locked=true { spawn "dms" "ipc" "call" "brightness" "decrement"; }
    XF86KbdBrightnessUp      allow-when-locked=true { spawn "brightnessctl" "-d" "*::kbd_backlight" "set" "5%+"; }
    XF86KbdBrightnessDown    allow-when-locked=true { spawn "brightnessctl" "-d" "*::kbd_backlight" "set" "5%-"; }

    // Media (playerctl)
    XF86AudioNext   allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPause  allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPlay   allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev   allow-when-locked=true { spawn "playerctl" "previous"; }

    // Function keys
    XF86Display { power-off-monitors; }
    XF86RFKill  { spawn "rfkill" "toggle" "all"; }
    XF86Sleep   allow-when-locked=true { spawn "systemctl" "suspend"; }
}

// Place DMS's wallpaper inside niri's overview backdrop so the overview
// shows the wallpaper instead of a solid color. Pairs with
// `layout.background-color "transparent"` above.
//
// Note: niri has no native window blur. Hyprland's blurred-terminal
// look cannot be reproduced here — DMS's blurredWallpaperLayer trick
// blurs the wallpaper *everywhere*, not just behind transparent
// windows, so it's not used.
layer-rule {
    match namespace="^quickshell$"
    place-within-backdrop true
}

// Hyprland windowrules → niri window-rule

// Float small utility/system windows
window-rule {
    match app-id=r#"^org\.pulseaudio\.pavucontrol$"#
    open-floating true
}

window-rule {
    match app-id=r#"^nm-connection-editor$"#
    open-floating true
}

window-rule {
    match app-id=r#"^\.?blueman-manager(-wrapped)?$"#
    open-floating true
}

window-rule {
    match app-id=r#"^1Password$"#
    open-floating true
}

window-rule {
    match app-id=r#"^jetbrains-toolbox$"#
    open-floating true
}

window-rule {
    match app-id=r#"^Emulator$"#
    open-floating true
}

// Terminal transparency is handled by Ghostty's own `background-opacity`
// (only fades the bg, keeps text fully opaque). niri's `opacity` would
// dim glyphs too — avoid it for terminals.

// Consistent rounded corners (Hyprland decoration.rounding=12).
// draw-border-with-background false: render border as a thin outline
// rather than a solid backing rectangle behind the window. Without
// this, opaque CSD apps (Zen, Thunar, Firefox-likes) hide the
// wallpaper in the gap area — ghostty looks fine only because it
// paints alpha across its surface.
//
// open-maximized false / open-maximized-to-edges false: refuse the
// "maximized" state apps request on startup (Zen, Thunar restore
// their saved maximized state). niri's "maximized to edges" hides
// struts, gaps, and borders, and squares off corners — looks like a
// black halo around the window. Force tiled-with-gaps behavior instead.
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
    draw-border-with-background false
    open-maximized false
    open-maximized-to-edges false
}
