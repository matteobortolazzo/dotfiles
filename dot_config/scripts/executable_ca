#!/usr/bin/env bash
# ca — coding-agent launcher for Claude Code and Codex.
#
# Claude Code:
#   ca       Sonnet (default)
#   ca cs    Sonnet
#   ca co    Opus
#   ca ch    Haiku
#   ca cf    Fable
#   ca c1    Opus with 1M context
#
# Codex:
#   ca x     Configured default model
#   ca xs    GPT-5.6 Sol
#   ca xt    GPT-5.6 Terra
#   ca xl    GPT-5.6 Luna
#
# Extra arguments pass through to the selected CLI. Use `--` to stop selector
# parsing when a prompt begins with a selector-like word.
set -euo pipefail

readonly CLAUDE_SUBAGENT_MODEL=claude-sonnet-5

usage() {
  cat <<'EOF'
Usage: ca [selector] [arguments...]

Claude Code (default provider):
  ca, ca cs  Sonnet
  ca co      Opus
  ca ch      Haiku
  ca cf      Fable
  ca c1      Opus with 1M context

Codex:
  ca x       Configured default model
  ca xs      GPT-5.6 Sol
  ca xt      GPT-5.6 Terra
  ca xl      GPT-5.6 Luna

All remaining arguments are passed through. Use `--` to stop selector parsing.
EOF
}

run_claude() {
  local model="$1"
  shift
  CLAUDE_CODE_SUBAGENT_MODEL="$CLAUDE_SUBAGENT_MODEL" \
    exec claude --model "$model" "$@"
}

run_codex() {
  case "${1:-}" in
    s|sol)
      shift
      exec codex --model gpt-5.6-sol "$@"
      ;;
    t|terra)
      shift
      exec codex --model gpt-5.6-terra "$@"
      ;;
    l|luna)
      shift
      exec codex --model gpt-5.6-luna "$@"
      ;;
    --)
      shift
      exec codex "$@"
      ;;
    *)
      exec codex "$@"
      ;;
  esac
}

case "${1:-}" in
  '')
    run_claude sonnet
    ;;
  help|-h|--help)
    usage
    ;;
  --)
    shift
    run_claude sonnet "$@"
    ;;
  cs|s|sonnet)
    shift
    run_claude sonnet "$@"
    ;;
  co|o|opus)
    shift
    if [[ "${1:-}" == 1m ]]; then
      shift
      run_claude 'opus[1m]' "$@"
    fi
    run_claude opus "$@"
    ;;
  ch|h|haiku)
    shift
    run_claude haiku "$@"
    ;;
  cf|f|fable)
    shift
    run_claude fable "$@"
    ;;
  c1|1m)
    shift
    run_claude 'opus[1m]' "$@"
    ;;
  xs)
    shift
    run_codex s "$@"
    ;;
  xt)
    shift
    run_codex t "$@"
    ;;
  xl)
    shift
    run_codex l "$@"
    ;;
  x|codex)
    shift
    run_codex "$@"
    ;;
  *)
    run_claude sonnet "$@"
    ;;
esac
