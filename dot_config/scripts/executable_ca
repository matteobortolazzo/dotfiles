#!/usr/bin/env bash
# ca — coding-agent launcher for Claude Code and Codex.
#
# By default agents run inside the agent-sandbox container (via the
# `agent-sand`/`codex-sand` launchers). Pass --no-sandbox to run on the host.
#
# Claude Code:
#   ca       Sonnet (default)
#   ca cs    Sonnet
#   ca co    Opus
#   ca ch    Haiku
#   ca cf    Fable
#   ca c1    Opus with 1M context
#
# Codex:
#   ca x     Configured default model
#   ca xs    GPT-5.6 Sol
#   ca xt    GPT-5.6 Terra
#   ca xl    GPT-5.6 Luna
#
# Extra arguments pass through to the selected CLI. Use `--` to stop selector
# parsing when a prompt begins with a selector-like word.
set -euo pipefail

readonly CLAUDE_SUBAGENT_MODEL=claude-sonnet-5

usage() {
  cat <<'EOF'
Usage: ca [--no-sandbox] [selector] [arguments...]

Claude Code (default provider):
  ca, ca cs  Sonnet
  ca co      Opus
  ca ch      Haiku
  ca cf      Fable
  ca c1      Opus with 1M context

Codex:
  ca x       Configured default model
  ca xs      GPT-5.6 Sol
  ca xt      GPT-5.6 Terra
  ca xl      GPT-5.6 Luna

Sandbox:
  Agents run inside the agent-sandbox container by default.
  --no-sandbox   Run the agent directly on the host instead.

All remaining arguments are passed through. Use `--` to stop selector parsing.
EOF
}

# Sandbox by default; --no-sandbox (or --host) drops to the host binaries.
SANDBOX=true

run_claude() {
  local model="$1"
  shift
  if "$SANDBOX"; then
    if ! command -v agent-sand &>/dev/null; then
      echo "ca: agent-sand not found on PATH — install agent-sandbox or use --no-sandbox." >&2
      exit 1
    fi
    exec agent-sand --model "$model" "$@"
  fi
  CLAUDE_CODE_SUBAGENT_MODEL="$CLAUDE_SUBAGENT_MODEL" \
    exec claude --model "$model" "$@"
}

run_codex() {
  local -a codex_cmd
  if "$SANDBOX"; then
    if ! command -v codex-sand &>/dev/null; then
      echo "ca: codex-sand not found on PATH — install agent-sandbox or use --no-sandbox." >&2
      exit 1
    fi
    codex_cmd=(codex-sand)
  else
    codex_cmd=(codex)
  fi
  case "${1:-}" in
    s|sol)
      shift
      exec "${codex_cmd[@]}" --model gpt-5.6-sol "$@"
      ;;
    t|terra)
      shift
      exec "${codex_cmd[@]}" --model gpt-5.6-terra "$@"
      ;;
    l|luna)
      shift
      exec "${codex_cmd[@]}" --model gpt-5.6-luna "$@"
      ;;
    --)
      shift
      exec "${codex_cmd[@]}" "$@"
      ;;
    *)
      exec "${codex_cmd[@]}" "$@"
      ;;
  esac
}

# Pull the sandbox flags out of the argument list before selector parsing.
# Stop consuming them once a literal `--` appears so a prompt can still contain
# the word `--no-sandbox` verbatim.
ARGS=()
passthrough=false
for arg in "$@"; do
  if "$passthrough"; then
    ARGS+=("$arg")
    continue
  fi
  case "$arg" in
    --) passthrough=true; ARGS+=("$arg") ;;
    --no-sandbox|--host) SANDBOX=false ;;
    --sandbox) SANDBOX=true ;;
    *) ARGS+=("$arg") ;;
  esac
done
set -- ${ARGS[@]+"${ARGS[@]}"}

case "${1:-}" in
  '')
    run_claude sonnet
    ;;
  help|-h|--help)
    usage
    ;;
  --)
    shift
    run_claude sonnet "$@"
    ;;
  cs|s|sonnet)
    shift
    run_claude sonnet "$@"
    ;;
  co|o|opus)
    shift
    if [[ "${1:-}" == 1m ]]; then
      shift
      run_claude 'opus[1m]' "$@"
    fi
    run_claude opus "$@"
    ;;
  ch|h|haiku)
    shift
    run_claude haiku "$@"
    ;;
  cf|f|fable)
    shift
    run_claude fable "$@"
    ;;
  c1|1m)
    shift
    run_claude 'opus[1m]' "$@"
    ;;
  xs)
    shift
    run_codex s "$@"
    ;;
  xt)
    shift
    run_codex t "$@"
    ;;
  xl)
    shift
    run_codex l "$@"
    ;;
  x|codex)
    shift
    run_codex "$@"
    ;;
  *)
    run_claude sonnet "$@"
    ;;
esac
