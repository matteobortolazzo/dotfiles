#!/usr/bin/env bash
# ccc — Claude Code launcher.
#   ccc             default 200k Opus 4.6 (settings.json default)
#   ccc 1m  [...]   Opus 4.6 @ 1M context, subagents stay at 200k
#   ccc fable [...] Fable 5,               subagents stay at 200k
# Extra args pass through to `claude`.
#
# CLAUDE_CODE_SUBAGENT_MODEL is the highest-precedence subagent control, so in a
# 1M/Fable session every inheriting subagent is forced to bare 200k Opus — this
# stops subagents that don't support 1M from breaking on inheritance.
set -euo pipefail

case "${1:-}" in
  1m)
    shift
    CLAUDE_CODE_SUBAGENT_MODEL=claude-opus-4-6 exec claude --model 'claude-opus-4-6[1m]' "$@"
    ;;
  fable)
    shift
    CLAUDE_CODE_SUBAGENT_MODEL=claude-opus-4-6 exec claude --model 'fable[1m]' "$@"
    ;;
  *)
    exec claude --model claude-opus-4-6 "$@"
    ;;
esac
