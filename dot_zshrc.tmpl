# Path
{{ if eq .profile "main" -}}
export PATH=/opt/webp:$PATH
{{ end -}}
export PATH="$HOME/.config/scripts:$PATH"
export PATH="$HOME/.dotnet:$HOME/.dotnet/tools:$PATH"
export PATH="$HOME/.aspire/bin:$PATH"
export PATH="$HOME/.bun/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"
{{ if eq .profile "mac" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

# Editor
export EDITOR=nvim
export VISUAL=nvim

# Environment Variables
export DOTNET_ROOT="$HOME/.dotnet"
export DOTNET_CLI_TELEMETRY_OPTOUT=1
{{ if eq .profile "wsl" -}}
export BROWSER=wslview
{{ end -}}
export KUBECONFIG=~/.kube/config
export ZSH="$HOME/.oh-my-zsh"

# fnm
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
  export PATH="$FNM_PATH:$PATH"
  eval "`fnm env`"
fi

# Custom environment variables
if [ -f ~/.config/environment ]; then
    source ~/.config/environment
fi

# Oh My Zsh Configuration
ZSH_THEME="robbyrussell"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting zsh-vi-mode kubectl)
source $ZSH/oh-my-zsh.sh

# Alias
alias v="nvim"
alias lg="lazygit"
alias yz="yazi"
alias tn="tmux new-session -s"
alias tl="tmux list-sessions"
alias ta="tmux attach-session"
{{ if ne .profile "mac" -}}
alias kubectl="k3s kubectl"
{{ end -}}
t() { tmux new-session -A -s "$(basename "$PWD")"; }

# zoxide initialization
eval "$(zoxide init zsh)"

# direnv — per-directory environment overrides
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# Load Angular CLI autocompletion.
if command -v ng &>/dev/null; then
  source <(ng completion script)
fi

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}
